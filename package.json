{
  "name": "infyrence",
  "version": "0.2.0",
  "description": "TypeScript SDK for the Infyrence AI inference API",
  "type": "module",
  "homepage": "https://infyrence.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Infyrence/typescript-sdk.git"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "tsc -p tsconfig.json --outDir dist/esm",
    "build:cjs": "tsc -p tsconfig.cjs.json --outDir dist/cjs",
    "build:types": "tsc -p tsconfig.json --outDir dist/types --declaration --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "infyrence",
    "ai",
    "inference",
    "llm",
    "openai-compatible",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
